drop database if exists SWbatallas;
create database SWbatallas;
use SWbatallas;

-- La primera tabla contiene las naves que han luchado en diferentes batallas
CREATE TABLE naves (
    nave_id INT PRIMARY KEY,
    modelo VARCHAR(100) NOT NULL, -- Ej: 'Star Destroyer'
    clase VARCHAR(50)  NOT NULL, -- 'destructor', 'caza', 'crucero', 'estación'
    faccion VARCHAR(50)  NOT NULL, -- 'Imperio', 'Rebelión', 'República', 'Separatistas'
    longitud_m DECIMAL(10,2) NOT NULL -- Longitud en metros
);

-- La segunda tabla contiene las batallas que se han librado
CREATE TABLE batallas (
    batalla_id INT PRIMARY KEY,
    nombre VARCHAR(150) NOT NULL, -- Ej: 'Batalla de Yavin'
    ubicacion VARCHAR(100) NOT NULL, -- Sistema o planeta
    resultado VARCHAR(20)  NOT NULL, -- 'victoria Imperio', 'victoria Rebelión', etc.
    anio_galactico INT NOT NULL, -- Año en el calendario galáctico estándar
    nave_insignia_id INT NOT NULL, -- Nave principal que participó
    CONSTRAINT fk_batallas_naves
		FOREIGN KEY (nave_insignia_id) REFERENCES naves(nave_id)
);

